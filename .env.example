# Environment Variables for prism-pdp-variant-factory
# Copy this file to .env and adjust values as needed.

# Application title displayed in the browser tab and header
VITE_APP_TITLE=Prism PDP Variant Factory

# Prefix used for localStorage keys to avoid collisions with other apps
VITE_STORAGE_PREFIX=prism-pdp

# Whether to seed sample product data on initial page load (true/false)
VITE_SEED_ON_LOAD=true